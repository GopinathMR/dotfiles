{
  "env": {
    "USE_BUILTIN_RIPGREP": "1"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if claude plugin list --installed | grep -q 'feature-dev'; then echo '✅ Plugin feature-dev is active.'; else echo '⚠️ Warning: Plugin xyz not found or disabled. Run /plugin to install.'; fi"
          },
          {
            "type": "command",
            "command": "if claude plugin list --installed | grep -q 'git-pr-workflows'; then echo '✅ Plugin git-pr-workflows is active.'; else echo '⚠️ Warning: Plugin xyz not found or disabled. Run /plugin to install.'; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "ghostty-notifications@recursechat-agent-workflow": true,
    "obsidian@obsidian-skills": true,
    "jetty-core@jetty": true,
    "jetty-eng@jetty": true,
    "jetty-mgmt@jetty": true,
    "jetty-infra@jetty": true,
    "jetty-python@jetty": true,
    "jetty-csharp@jetty": true,
    "jetty-react@jetty": true,
    "agent-orchestration@claude-code-workflows": true,
    "cicd-automation@claude-code-workflows": true,
    "cloud-infrastructure@claude-code-workflows": true,
    "code-documentation@claude-code-workflows": true,
    "code-refactoring@claude-code-workflows": true,
    "codebase-cleanup@claude-code-workflows": true,
    "comprehensive-review@claude-code-workflows": true,
    "context-management@claude-code-workflows": true,
    "database-design@claude-code-workflows": true,
    "database-migrations@claude-code-workflows": true,
    "developer-essentials@claude-code-workflows": true,
    "documentation-generation@claude-code-workflows": true,
    "git-pr-workflows@claude-code-workflows": true,
    "security-scanning@claude-code-workflows": true,
    "tdd-workflows@claude-code-workflows": true,
    "unit-testing@claude-code-workflows": true,
    "api-scaffolding@claude-code-workflows": true,
    "api-testing-observability@claude-code-workflows": true,
    "backend-api-security@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "python-development@claude-code-workflows": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "javascript-typescript@claude-code-workflows": true,
    "ui-design@claude-code-workflows": true,
    "voltagent-core-dev@voltagent-subagents": true,
    "voltagent-lang@voltagent-subagents": true,
    "voltagent-infra@voltagent-subagents": true,
    "voltagent-dev-exp@voltagent-subagents": true,
    "voltagent-meta@voltagent-subagents": true,
    "voltagent-research@voltagent-subagents": true,
    "jetty-experimental@jetty": true,
    "jetty-java@jetty": true,
    "example-skills@anthropic-agent-skills": true,
    "n8n-mcp-skills@n8n-mcp-skills": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "jetty": {
      "source": {
        "source": "directory",
        "path": "/Users/gopinath/github/overjet/jetty"
      },
      "autoUpdate": true
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      },
      "autoUpdate": true
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      },
      "autoUpdate": true
    },
    "voltagent-subagents": {
      "source": {
        "source": "github",
        "repo": "VoltAgent/awesome-claude-code-subagents"
      },
      "autoUpdate": true
    },
    "n8n-mcp-skills": {
      "source": {
        "source": "github",
        "repo": "czlonkowski/n8n-skills"
      },
      "autoUpdate": true
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "preferredNotifChannel": "ghostty",
  "voiceEnabled": true
}
